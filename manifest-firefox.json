{
  "manifest_version": 2,
  "name": "ScreenZen – Digital Wellness & Focus",
  "version": "1.0.0",
  "description": "Manage screen time, enforce focus sessions, and stay healthy with eye care, movement and hydration reminders.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["background/background-ff.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tabguard@extension",
      "strict_min_version": "109.0"
    }
  }
}
